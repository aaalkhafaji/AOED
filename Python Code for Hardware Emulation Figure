# 4. Generate the Publication Figure
# ==========================================
# Create a custom colormap going from Dark Gray (128) -> Orange -> Red (1023)
colors = [(0.8, 0.8, 0.8), (1, 0.6, 0.2), (0.8, 0.1, 0.1)] 
cmap_custom = mcolors.LinearSegmentedColormap.from_list("ThermalStress", colors, N=1024)

fig, axes = plt.subplots(1, 2, figsize=(12, 6))

plot_grid(axes[0], initial_grid, "Before Compensation\n(Critical Stress State $S_1$)", cmap_custom)
plot_grid(axes[1], compensated_grid, "After $II=1$ Diffusion\n(Thermal Offload)", cmap_custom)

