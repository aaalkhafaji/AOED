def hardware_spatial_coupling(image_matrix, max_val=1023, critical_threshold=1023):
    """
    Emulates the hardware-constrained actuarial spatial coupling (II=1).
    Uses 10-bit integer architecture with saturation arithmetic and bitwise shifts.
    """
    # Initialize output buffer
    output_matrix = np.copy(image_matrix).astype(np.int32)
    rows, cols = output_matrix.shape

    # Track diffused additions separately to simulate simultaneous clock cycle
    diffusion_buffer = np.zeros_like(output_matrix)

    for r in range(rows):
        for c in range(cols):
            # Check for Critical Markov State S1
            if image_matrix[r, c] >= critical_threshold:
                # Calculate thermal offload via bitwise right-shift (>> 3 is /8)
                delta_u = int(image_matrix[r, c]) >> 3
                
                # Conserve localized optical centroid (Target pixel subtracts 4 * delta)
                output_matrix[r, c] -= 4 * delta_u
                
                # Diffuse to 4-connected von Neumann neighbors
                if r > 0: diffusion_buffer[r-1, c] += delta_u        # Top
                if r < rows-1: diffusion_buffer[r+1, c] += delta_u   # Bottom
                if c > 0: diffusion_buffer[r, c-1] += delta_u        # Left
                if c < cols-1: diffusion_buffer[r, c+1] += delta_u   # Right

    # Apply saturation arithmetic (\oplus)
    for r in range(rows):
        for c in range(cols):
            output_matrix[r, c] = min(output_matrix[r, c] + diffusion_buffer[r, c], max_val)

    return output_matrix

def plot_grid(ax, matrix, title, cmap):
    """Helper function to plot the grid with numbers, matching the paper's TikZ style."""
    cax = ax.imshow(matrix, cmap=cmap, vmin=0, vmax=1023)
    ax.set_title(title, fontsize=14, fontweight='bold', pad=15)
    
    # Add the text annotations inside the grid
    rows, cols = matrix.shape
    for i in range(rows):
        for j in range(cols):
            val = matrix[i, j]
            color = 'black' if val > 700 else ('black' if val < 200 else 'white')
            fontweight = 'bold' if val != 128 else 'normal'
            ax.text(j, i, str(val), ha='center', va='center', 
                    color=color, fontsize=16, fontweight=fontweight)
            
    # Clean up grid lines
    ax.set_xticks(np.arange(-.5, cols, 1), minor=True)
    ax.set_yticks(np.arange(-.5, rows, 1), minor=True)
    ax.grid(which="minor", color="black", linestyle='-', linewidth=2)
    ax.tick_params(which="minor", bottom=False, left=False)
    ax.set_xticks([])
    ax.set_yticks([])

# ==========================================
# 1. Setup the 10-Bit Test Data (From Section III.D)
# ==========================================
# 3x3 Grid: Center pixel at max 10-bit thermal stress (1023), neighbors at 128
initial_grid = np.array([
    [128, 128, 128],
    [128, 1023, 128],
    [128, 128, 128]
], dtype=np.int32)

# ==========================================
# 2. Execute the Hardware Algorithm
# ==========================================
compensated_grid = hardware_spatial_coupling(initial_grid)

# ==========================================
# 3. Prove Mathematical Conservation
# ==========================================
initial_luminance = np.sum(initial_grid)
compensated_luminance = np.sum(compensated_grid)

print("-" * 50)
print("ACTUARIAL SPATIAL COUPLING VERIFICATION")
print("-" * 50)
print(f"Total Luminance Before: {initial_luminance}")
print(f"Total Luminance After:  {compensated_luminance}")
if initial_luminance == compensated_luminance:
    print("=> SUCCESS: L <= 1 Stability Confirmed. Total optical centroid strictly conserved!")
else:
    print("=> WARNING: Luminance conservation failed (Likely due to saturation \oplus).")
print("-" * 50)

